{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the main desktop window",
  "windows": ["main", "roi-overlay", "assistant-bubble"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/GenshinArtifactScanner.Win",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
