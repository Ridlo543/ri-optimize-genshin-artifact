{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Genshin Artifact Assistant",
  "version": "0.1.0",
  "identifier": "dev.ri-genshin.artifact-assistant",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:tauri",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Genshin Artifact Assistant",
        "width": 860,
        "height": 760,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "visible": false,
        "center": true
      },
      {
        "label": "roi-overlay",
        "title": "Artifact ROI Overlay",
        "url": "index.html?window=roi-overlay",
        "width": 1280,
        "height": 800,
        "minWidth": 320,
        "minHeight": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "x": 0,
        "y": 0
      },
      {
        "label": "assistant-bubble",
        "title": "Artifact Assistant Bubble",
        "url": "index.html?window=assistant-bubble",
        "width": 72,
        "height": 72,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "x": 32,
        "y": 72
      },
      {
        "label": "fixture-playground",
        "title": "Fixture Playground",
        "url": "index.html?window=fixture-playground&fixture=character-plus20",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "externalBin": [
      "binaries/GenshinArtifactScanner.Win"
    ],
    "resources": [
      "binaries/*.dll",
      "binaries/*.json",
      "binaries/tessdata"
    ]
  }
}
