{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Genshin Artifact Assistant",
  "version": "0.1.0",
  "identifier": "dev.ri-genshin.artifact-assistant",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:tauri",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Genshin Artifact Assistant",
        "width": 460,
        "height": 720,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "center": false,
        "x": 32,
        "y": 72
      },
      {
        "label": "roi-overlay",
        "title": "Artifact ROI Overlay",
        "url": "index.html?window=roi-overlay",
        "width": 1280,
        "height": 800,
        "minWidth": 320,
        "minHeight": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "x": 0,
        "y": 0
      },
      {
        "label": "assistant-bubble",
        "title": "Artifact Assistant Bubble",
        "url": "index.html?window=assistant-bubble",
        "width": 340,
        "height": 220,
        "minWidth": 260,
        "minHeight": 120,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "x": 1520,
        "y": 120
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "externalBin": [
      "binaries/GenshinArtifactScanner.Win"
    ],
    "resources": [
      "binaries/*.dll",
      "binaries/*.json",
      "binaries/tessdata"
    ]
  }
}
