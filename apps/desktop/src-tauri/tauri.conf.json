{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Genshin Artifact Assistant",
  "version": "0.1.0",
  "identifier": "dev.ri-genshin.artifact-assistant",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Genshin Artifact Assistant",
        "width": 460,
        "height": 720,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "center": false,
        "x": 32,
        "y": 72
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility"
  }
}
